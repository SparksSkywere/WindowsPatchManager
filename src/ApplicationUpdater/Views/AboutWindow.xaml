<Window x:Class="ApplicationUpdater.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Windows Patch Manager"
        Height="380" Width="460"
        MinHeight="320" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource WindowBackgroundBrush}"
        Icon="pack://application:,,,/Assets/app.ico">

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="88" Height="28" IsDefault="True" IsCancel="True"
                    Click="Ok_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>

        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Image x:Name="AppIconImage" Width="48" Height="48" Margin="0,0,14,0"
                       Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold"
                               Text="Windows Patch Manager"/>
                    <TextBlock x:Name="VersionText" Style="{StaticResource MutedTextStyle}"
                               Margin="0,4,0,0" Text="Version"/>
                </StackPanel>
            </StackPanel>

            <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" Margin="0,0,0,16"
                       LineHeight="20"/>

            <Border Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushSubtle}"
                    BorderThickness="1" Padding="12" CornerRadius="3">
                <StackPanel>
                    <TextBlock Text="Created by" Style="{StaticResource MutedTextStyle}" FontSize="11"/>
                    <TextBlock x:Name="CompanyText" FontWeight="SemiBold" Margin="0,2,0,8"
                               Text="Skywere Industries"/>
                    <TextBlock x:Name="CopyrightText" Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
