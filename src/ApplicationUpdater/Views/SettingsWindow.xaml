<Window x:Class="ApplicationUpdater.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options"
        Height="560" Width="560"
        MinHeight="480" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Icon="pack://application:,,,/Assets/app.ico">

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="88" Height="28" Margin="0,0,8,0"
                    IsDefault="True" Click="Ok_Click"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="Cancel" Width="88" Height="28"
                    IsCancel="True" Click="Cancel_Click"
                    Style="{StaticResource ToolbarButtonStyle}"/>
        </StackPanel>

        <TabControl>
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Startup &amp; scanning" Style="{StaticResource SectionHeaderStyle}"/>
                        <CheckBox Content="Automatically check for updates on launch"
                                  IsChecked="{Binding AutoCheckUpdates}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Check interval (hours):" VerticalAlignment="Center" Width="160"/>
                            <TextBox Width="60" Text="{Binding CheckIntervalHours}"/>
                        </StackPanel>
                        <CheckBox Content="Write a backup manifest before installing updates"
                                  IsChecked="{Binding CreateBackups}" Margin="0,10,0,0"/>

                        <TextBlock Text="Update sources" Style="{StaticResource SectionHeaderStyle}" Margin="0,18,0,8"/>
                        <CheckBox Content="Windows Package Manager (winget)" IsChecked="{Binding WingetEnabled}"/>
                        <CheckBox Content="Chocolatey" IsChecked="{Binding ChocolateyEnabled}"/>

                        <TextBlock Text="Configuration file" Style="{StaticResource SectionHeaderStyle}" Margin="0,18,0,8"/>
                        <TextBox Text="{Binding ConfigPath}" IsReadOnly="True"
                                 TextWrapping="Wrap" Background="#FFF8F8F8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Updates">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Install behavior" Style="{StaticResource SectionHeaderStyle}"/>
                        <CheckBox Content="Ask for confirmation before installing updates"
                                  IsChecked="{Binding RequireConfirmation}"/>
                        <CheckBox Content="Silent installers when supported" IsChecked="{Binding Silent}" Margin="0,6,0,0"/>
                        <CheckBox Content="Include packages with unknown version" IsChecked="{Binding IncludeUnknown}" Margin="0,6,0,0"/>
                        <CheckBox Content="Include pinned packages" IsChecked="{Binding IncludePinned}" Margin="0,6,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Max concurrent updates:" VerticalAlignment="Center" Width="160"/>
                            <TextBox Width="60" Text="{Binding MaxConcurrentUpdates}"/>
                        </StackPanel>
                        <TextBlock Text="Keep concurrency at 1–2 for more reliable installs."
                                   Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Exclusions">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="One entry per line. Matching programs are skipped during update checks."
                                   Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Text="Program names" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Height="70" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ExcludedProgramsText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Publishers" FontWeight="SemiBold" Margin="0,10,0,4"/>
                        <TextBox Height="50" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ExcludedPublishersText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Name keywords" FontWeight="SemiBold" Margin="0,10,0,4"/>
                        <TextBox Height="50" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ExcludedKeywordsText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Package IDs" FontWeight="SemiBold" Margin="0,10,0,4"/>
                        <TextBox Height="50" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ExcludedPackageIdsText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Notifications">
                <StackPanel Margin="12">
                    <CheckBox Content="Notify when updates are available" IsChecked="{Binding ShowUpdateAvailable}"/>
                    <CheckBox Content="Notify when updates complete" IsChecked="{Binding ShowUpdateComplete}" Margin="0,8,0,0"/>
                    <CheckBox Content="Show error dialogs" IsChecked="{Binding ShowErrors}" Margin="0,8,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
